# Copy to automation/.env

# ── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change_me

# ── Session ──────────────────────────────────────────────────
SESSION_PATH=./session/linkedin.json

# ── Playwright ───────────────────────────────────────────────
# true = visible browser window (recommended for local Mac)
BROWSER_HEADLESS=false
BROWSER_SLOW_MO_MS=50

# ── Delays (milliseconds) ────────────────────────────────────
DELAY_MIN_MS=800
DELAY_MAX_MS=2500
DELAY_BETWEEN_JOBS_MIN_MS=8000
DELAY_BETWEEN_JOBS_MAX_MS=15000

# ── User ID ──────────────────────────────────────────────────
# Must match the user ID from the backend database
USER_ID=
