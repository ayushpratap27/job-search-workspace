# Copy to backend/.env

# ── Server ───────────────────────────────────────────────────
PORT=8080
ENV=development

# ── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgres://jsw:change_me@localhost:5432/job_search_workspace?sslmode=disable

# ── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change_me

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── AI ───────────────────────────────────────────────────────
# Options: openai | gemini | none
AI_PROVIDER=none
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SUMMARY_RECIPIENT_EMAIL=

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173
